    const py=h*.5+Math.sin(a)*h*r*.7;
    ctx.fillStyle=col;circle(ctx,px,py,sz);
    // Saturn rings
    if(sz===10){ctx.strokeStyle='rgba(200,180,120,.4)';ctx.lineWidth=3;ctx.beginPath();ctx.ellipse(px,py,sz*2,sz*.5,.2,0,Math.PI*2);ctx.stroke();}
