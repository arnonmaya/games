}

function drawBlackHole(ctx,w,h){
  ctx.fillStyle='#000000';ctx.fillRect(0,0,w,h);
  stars(ctx,w,h,100,h,.8);
  // Accretion disk
  const diskCols=[
    [w*.09,'rgba(255,200,80,.7)'],
    [w*.13,'rgba(255,120,20,.5)'],
    [w*.18,'rgba(200,40,10,.3)'],
    [w*.25,'rgba(100,10,5,.1)'],
    [w*.35,'rgba(0,0,0,0)'],
  ];
  diskCols.forEach(([r,col])=>{
    const dg=ctx.createRadialGradient(w*.5,h*.5,r*.3,w*.5,h*.5,r);
    dg.addColorStop(0,col);dg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=dg;ctx.beginPath();ctx.ellipse(w*.5,h*.5,r*1.5,r*.4,.1,0,Math.PI*2);ctx.fill();
  });
  // Gravitational lensing arcs
  ctx.strokeStyle='rgba(255,220,100,.3)';ctx.lineWidth=2;
  for(let a=0;a<Math.PI*2;a+=.15){
    const r=w*.12+Math.sin(a*3)*w*.02;
    ctx.beginPath();ctx.arc(w*.5,h*.5,r,a,a+.1);ctx.stroke();
  }
  // Event horizon (pure black circle)
  ctx.fillStyle='#000000';circle(ctx,w*.5,h*.5,w*.07);
  // Photon ring
  ctx.strokeStyle='rgba(255,200,100,.5)';ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(w*.5,h*.5,w*.075,0,Math.PI*2);ctx.stroke();
  // Jet
  ctx.strokeStyle='rgba(100,180,255,.3)';ctx.lineWidth=6;
  ctx.beginPath();ctx.moveTo(w*.5,h*.5-w*.075);ctx.lineTo(w*.5,h*.05);ctx.stroke();
  ctx.beginPath();ctx.moveTo(w*.5,h*.5+w*.075);ctx.lineTo(w*.5,h*.95);ctx.stroke();
  ctx.strokeStyle='rgba(200,230,255,.15)';ctx.lineWidth=20;
  ctx.beginPath();ctx.moveTo(w*.5,h*.5-w*.075);ctx.lineTo(w*.5,h*.05);ctx.stroke();
  ctx.beginPath();ctx.moveTo(w*.5,h*.5+w*.075);ctx.lineTo(w*.5,h*.95);ctx.stroke();
}

