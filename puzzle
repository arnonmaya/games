    ctx.beginPath();ctx.moveTo(bx-sz*.1,by+sz*.75);ctx.lineTo(bx+sz*.1,by+sz*.75);ctx.lineTo(bx+sz*.08,by+sz*.95);ctx.lineTo(bx-sz*.08,by+sz*.95);ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,.2)';ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(bx,by+sz*.95);ctx.lineTo(bx-sz*.3,by+sz*1.5);ctx.lineTo(bx+sz*.3,by+sz*1.5);ctx.stroke();
    // Highlight
    ctx.fillStyle='rgba(255,255,255,.2)';ctx.beginPath();ctx.ellipse(bx-sz*.15,by-sz*.2,sz*.2,sz*.3,-.5,0,Math.PI*2);ctx.fill();
  }
  balloon(w*.18,h*.3,w*.06,'#e03040','#ff6070',h*.09);
  balloon(w*.38,h*.18,w*.06,'#f09010','#ffc040',h*.1);
  balloon(w*.57,h*.28,w*.06,'#2070c0','#60b0f0',h*.085);
  balloon(w*.76,h*.22,w*.06,'#20a040','#60d070',h*.095);
  balloon(w*.88,h*.35,w*.06,'#9030b0','#c060e0',h*.08);
}

