<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Picture Puzzle</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@400;500&display=swap');
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  :root{
    --bg:#0e0e10;--surface:#1a1a1e;--surface2:#242428;
    --border:rgba(255,255,255,0.08);--accent:#c8a96e;--accent2:#7eb8c8;
    --text:#f0ede8;--muted:rgba(240,237,232,0.45);--success:#6fcf97;
    --piece-border:rgba(255,255,255,0.12);--slot-dash:rgba(200,169,110,0.25);
  }
  body{font-family:'DM Mono',monospace;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:1.5rem 1rem;gap:1rem;}
  h1{font-family:'DM Serif Display',serif;font-size:clamp(1.4rem,4vw,2rem);letter-spacing:.02em;color:var(--accent);font-weight:400;}
  .subtitle{font-size:11px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;}
  .stats{display:flex;gap:1rem;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:.35rem 1rem;}
  .stat{text-align:center;}
  .sv{font-size:13px;font-weight:500;color:var(--text);}
  .sl{font-size:9px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-top:1px;}
  .game-area{display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;justify-content:center;}
  .side-panel{display:flex;flex-direction:column;gap:10px;min-width:120px;}
  .panel-label{font-size:10px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;}
  #prev{display:block;border-radius:8px;border:1px solid var(--border);transition:opacity .3s;}
  #board{position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);background:var(--surface);flex-shrink:0;}
  .slot{position:absolute;box-sizing:border-box;border:1.5px dashed var(--slot-dash);transition:background .15s,border-color .15s;cursor:pointer;}
  .slot:hover{background:rgba(200,169,110,.07);border-color:rgba(200,169,110,.5);}
  .slot.filled{border:none;cursor:default;pointer-events:none;}
  .slot canvas{display:block;position:absolute;top:0;left:0;}
  #tray-wrap{width:100%;max-width:800px;}
  #tray{display:flex;flex-direction:row;gap:6px;padding:10px 14px;background:var(--surface);border-radius:12px;border:1px solid var(--border);overflow-x:auto;overflow-y:hidden;align-items:center;min-height:72px;}
  #tray::-webkit-scrollbar{height:4px;}
  #tray::-webkit-scrollbar-track{background:transparent;}
  #tray::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:2px;}
  .piece{cursor:pointer;border-radius:4px;border:2px solid var(--piece-border);overflow:hidden;transition:border-color .15s,transform .1s;flex-shrink:0;}
  .piece:hover{border-color:var(--accent2);transform:scale(1.05);}
  .piece.sel{border-color:var(--accent);box-shadow:0 0 0 3px rgba(200,169,110,.3);transform:scale(1.05);}
  .piece canvas{display:block;}
  .controls{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;align-items:center;}
  button{font-family:'DM Mono',monospace;font-size:12px;padding:7px 16px;border-radius:8px;border:1px solid rgba(255,255,255,.15);background:var(--surface2);color:var(--text);cursor:pointer;letter-spacing:.05em;transition:background .15s,border-color .15s,transform .1s;}
  button:hover{background:var(--surface);border-color:var(--accent);}
  button:active{transform:scale(.97);}
  .diff-btn{font-size:11px;padding:5px 12px;color:var(--muted);}
  .diff-btn.on{color:var(--accent);border-color:rgba(200,169,110,.5);background:rgba(200,169,110,.08);}
  .win-msg{font-family:'DM Serif Display',serif;font-size:1.2rem;color:var(--success);min-height:1.5rem;text-align:center;font-weight:400;}
  .hint{font-size:11px;color:var(--muted);letter-spacing:.06em;text-align:center;}
  .correct-glow{outline:2px solid rgba(111,207,151,.75);}
  .cat-tabs{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;}
  .cat-btn{font-size:11px;padding:5px 14px;border-radius:20px;border:1px solid rgba(255,255,255,.1);background:transparent;color:var(--muted);cursor:pointer;letter-spacing:.06em;transition:all .15s;}
  .cat-btn:hover{border-color:var(--accent2);color:var(--accent2);}
  .cat-btn.on{background:rgba(126,184,200,.15);border-color:var(--accent2);color:var(--accent2);}
  .img-picker{display:flex;flex-wrap:wrap;gap:5px;justify-content:center;max-width:340px;}
  .img-btn{font-size:10px;padding:4px 10px;border-radius:5px;border:1px solid rgba(255,255,255,.08);background:transparent;color:var(--muted);cursor:pointer;letter-spacing:.06em;transition:all .15s;}
  .img-btn:hover{border-color:var(--accent);color:var(--accent);}
  .img-btn.on{border-color:var(--accent);color:var(--accent);background:rgba(200,169,110,.1);}

  /* Home button */
  .home-btn{display:inline-flex;align-items:center;gap:6px;font-family:'DM Mono',monospace;font-size:12px;padding:7px 16px;border-radius:8px;border:1px solid rgba(255,255,255,.15);background:var(--surface2);color:var(--text);cursor:pointer;letter-spacing:.05em;text-decoration:none;transition:background .15s,border-color .15s,transform .1s;}
  .home-btn:hover{background:var(--surface);border-color:var(--accent);}
  .home-btn:active{transform:scale(.97);}
  /* Music toggle */
  .music-btn{font-size:16px;padding:6px 12px;min-width:36px;}
  /* Touch controls - only shown on touch devices */
  #touch-controls{display:none;position:fixed;bottom:24px;right:20px;z-index:100;flex-direction:column;align-items:center;gap:10px;}
  #touch-controls.visible{display:flex;}
  .touch-row{display:flex;gap:10px;align-items:center;}
  .touch-btn{width:56px;height:56px;border-radius:50%;border:2px solid rgba(200,169,110,.5);background:rgba(26,26,30,.85);backdrop-filter:blur(8px);color:var(--text);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;user-select:none;-webkit-user-select:none;transition:background .12s,transform .1s;box-shadow:0 2px 12px rgba(0,0,0,.4);}
  .touch-btn:active{background:rgba(200,169,110,.2);transform:scale(.93);}
  .touch-btn.touch-select{background:rgba(200,169,110,.15);border-color:var(--accent);}
  /* Keyboard hint */
  .kb-hint{font-size:10px;color:var(--muted);text-align:center;letter-spacing:.06em;}
</style>
</head>
<body>
<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center;">
  <a href="https://arnonmaya.github.io/games/" class="home-btn">🏠 Back to Home Page</a>
  <button class="music-btn" id="music-btn" onclick="toggleMusic()" title="Toggle music">🎵</button>
</div>
<h1>Picture Puzzle</h1>
<p class="subtitle">Assemble the fragments</p>



<div class="cat-tabs" id="cat-tabs"></div>
<div class="img-picker" id="img-picker"></div>

<div class="game-area">
  <div class="side-panel">
    <div class="panel-label">Reference</div>
    <canvas id="prev" width="110" height="110"></canvas>
  </div>
  <div>
    <div class="panel-label" style="margin-bottom:5px;">Board — select a piece, then click a slot</div>
    <div id="board"></div>
  </div>
</div>
<div id="tray-wrap">
  <div class="panel-label" style="margin-bottom:6px;">Pieces — scroll to see all</div>
  <div id="tray"></div>
</div>

<div class="win-msg" id="wm"></div>
<div class="hint" id="ht">Select a piece from the tray, then click a slot on the board.</div>

<div class="controls">
  <button onclick="ng()">↺ New game</button>
  <button onclick="togPrev()">◑ Toggle preview</button>
  <div style="display:flex;gap:5px;">
    <button class="diff-btn" onclick="setN(3)">3×3</button>
    <button class="diff-btn on" onclick="setN(4)">4×4</button>
    <button class="diff-btn" onclick="setN(5)">5×5</button>
  </div>
</div>
<p class="kb-hint" id="kb-hint" style="display:none;">⌨️ Arrow keys: navigate tray &nbsp;|&nbsp; Enter / Space: select &amp; place &nbsp;|&nbsp; N: new game &nbsp;|&nbsp; P: preview</p>

<div id="touch-controls">
  <div class="touch-row">
    <div class="touch-btn" id="tc-left" title="Previous piece">◀</div>
    <div class="touch-btn touch-select" id="tc-select" title="Select / Place piece">✓</div>
    <div class="touch-btn" id="tc-right" title="Next piece">▶</div>
  </div>
  <div class="touch-row">
    <div class="touch-btn" id="tc-new" title="New game">↺</div>
    <div class="touch-btn" id="tc-prev" title="Toggle preview">◑</div>
    <div class="touch-btn" id="tc-music" title="Toggle music">🎵</div>
  </div>
</div>

<script>
// ── Scenes ────────────────────────────────────────────────────────────
const SCENES = [
  {name:'Mountain Lake', cat:'Nature',   fn:drawMountain},
  {name:'Forest Path',   cat:'Nature',   fn:drawForest},
  {name:'Ocean Night',   cat:'Nature',   fn:drawOcean},
  {name:'Desert Dunes',  cat:'Nature',   fn:drawDesert},
  {name:'Snowy Valley',  cat:'Nature',   fn:drawSnow},
  {name:'Autumn Park',   cat:'Nature',   fn:drawAutumn},
  {name:'Tropical Beach',cat:'Nature',   fn:drawBeach},
  {name:'Waterfall',     cat:'Nature',   fn:drawWaterfall},
  {name:'Volcano',       cat:'Nature',   fn:drawVolcano},
  {name:'Night City',    cat:'Cities',   fn:drawCity},
  {name:'Rainy Street',  cat:'Cities',   fn:drawRainy},
  {name:'Harbor Dusk',   cat:'Cities',   fn:drawHarbor},
  {name:'Ancient Ruins', cat:'Cities',   fn:drawRuins},
  {name:'Japanese Temple',cat:'Cities',  fn:drawTemple},
  {name:'Lighthouse',    cat:'Cities',   fn:drawLighthouse},
  {name:'Hot Air Balloons',cat:'Cities', fn:drawBalloons},
  {name:'Starfield',     cat:'Space',    fn:drawStars},
  {name:'Nebula',        cat:'Space',    fn:drawNebula},
  {name:'Aurora',        cat:'Space',    fn:drawAurora},
  {name:'Alien Planet',  cat:'Space',    fn:drawAlien},
  {name:'Solar System',  cat:'Space',    fn:drawSolar},
  {name:'Black Hole',    cat:'Space',    fn:drawBlackHole},
  {name:'Koi Pond',      cat:'Animals',  fn:drawKoi},
  {name:'Arctic Scene',  cat:'Animals',  fn:drawArctic},
  {name:'Jungle',        cat:'Animals',  fn:drawJungle},
  {name:'Savanna',       cat:'Animals',  fn:drawSavanna},
  {name:'Coral Reef',    cat:'Animals',  fn:drawReef},
  {name:'Bird Migration',cat:'Animals',  fn:drawBirds},
];

// ── State ─────────────────────────────────────────────────────────────
let N=4,SZ=90,sel=null,moves=0,secs=0,tInt=null,going=false;
let bState=[],pieces=[],imgIdx=0,showPrev=true,curCat='Nature';
const CS=360;
let mc,mx;

// ── Helper primitives ─────────────────────────────────────────────────
function tri(c,x1,y1,x2,y2,x3,y3){c.beginPath();c.moveTo(x1,y1);c.lineTo(x2,y2);c.lineTo(x3,y3);c.fill();}
function circle(c,x,y,r){c.beginPath();c.arc(x,y,r,0,Math.PI*2);c.fill();}
function pineTree(c,x,base,tw,th){
  c.beginPath();c.moveTo(x,base-th);c.lineTo(x-tw,base);c.lineTo(x+tw,base);c.fill();
  c.beginPath();c.moveTo(x,base-th*.6);c.lineTo(x-tw*1.4,base-th*.2);c.lineTo(x+tw*1.4,base-th*.2);c.fill();
}
function bigTree(c,x,base,tw,th){
  const col=c.fillStyle;
  c.fillStyle='rgba(0,0,0,.5)';c.fillRect(x-tw*.3,base-th*.22,tw*.6,th*.26);c.fillStyle=col;
  c.beginPath();c.moveTo(x,base-th);c.lineTo(x-tw,base-th*.52);c.lineTo(x+tw,base-th*.52);c.fill();
  c.beginPath();c.moveTo(x,base-th*.62);c.lineTo(x-tw*1.45,base-th*.2);c.lineTo(x+tw*1.45,base-th*.2);c.fill();
  c.beginPath();c.moveTo(x,base-th*.28);c.lineTo(x-tw*1.8,base);c.lineTo(x+tw*1.8,base);c.fill();
}
function cloud(c,x,y,s){
  c.beginPath();c.arc(x,y,s,0,Math.PI*2);c.fill();
  c.beginPath();c.arc(x+s*.9,y+s*.1,s*.75,0,Math.PI*2);c.fill();
  c.beginPath();c.arc(x-s*.8,y+s*.15,s*.7,0,Math.PI*2);c.fill();
  c.beginPath();c.arc(x+s*.4,y-s*.5,s*.6,0,Math.PI*2);c.fill();
}
function cactus(c,x,base,w,h){
  c.fillRect(x-w*.5,base-h,w,h);
  c.fillRect(x-w*2,base-h*.6,w*1.5,w);c.fillRect(x-w*2,base-h*.6-w,w,h*.25);
  c.fillRect(x+w*.5,base-h*.5,w*1.5,w);c.fillRect(x+w*1.5,base-h*.5-w,w,h*.2);
}
function stars(c,w,h,n,maxY,alpha){
  c.fillStyle=`rgba(255,255,255,${alpha||0.8})`;
  for(let i=0;i<n;i++){circle(c,Math.random()*w,Math.random()*(maxY||h),.5+Math.random()*.8);}
}
function gradRect(c,x,y,w,h,stops){
  const g=c.createLinearGradient(x,y,x,y+h);
  stops.forEach(([p,col])=>g.addColorStop(p,col));
  c.fillStyle=g;c.fillRect(x,y,w,h);
}

// ── NATURE ────────────────────────────────────────────────────────────
function drawMountain(ctx,w,h){
  gradRect(ctx,0,0,w,h*.55,[[0,'#0c2d54'],[1,'#6ea8d4']]);
  stars(ctx,w,h,40,h*.35,.8);
  ctx.fillStyle='#2a2060';tri(ctx,0,h*.55,w*.22,h*.15,w*.46,h*.55);
  ctx.fillStyle='#3d34a0';tri(ctx,w*.18,h*.55,w*.5,h*.06,w*.82,h*.55);
  ctx.fillStyle='#2a2060';tri(ctx,w*.58,h*.55,w*.84,h*.18,w,h*.55);
  ctx.fillStyle='#dde8f5';
  tri(ctx,w*.5,h*.06,w*.42,h*.2,w*.58,h*.2);
  tri(ctx,w*.84,h*.18,w*.78,h*.28,w*.9,h*.28);
  tri(ctx,w*.22,h*.15,w*.16,h*.25,w*.28,h*.25);
  gradRect(ctx,0,h*.55,w,h*.45,[[0,'#3a7fc1'],[1,'#0c2d54']]);
  ctx.strokeStyle='rgba(255,255,255,.12)';ctx.lineWidth=2;
  for(let i=0;i<8;i++){ctx.beginPath();ctx.moveTo(w*(.06+i*.12),h*(.65+i*.01));ctx.lineTo(w*(.14+i*.12),h*(.65+i*.01));ctx.stroke();}
  ctx.fillStyle='#0a3d2c';
  for(let i=0;i<8;i++)pineTree(ctx,w*.04+i*w*.13,h*.555,w*.025,h*.14);
}

function drawForest(ctx,w,h){
  gradRect(ctx,0,0,w,h*.32,[[0,'#1a3a5c'],[1,'#c8956e']]);
  ctx.fillStyle='rgba(255,200,80,.9)';circle(ctx,w*.5,h*.28,w*.055);
  ctx.fillStyle='rgba(255,200,80,.12)';circle(ctx,w*.5,h*.28,w*.1);
  gradRect(ctx,0,h*.68,w,h*.32,[[0,'#3a5e1a'],[1,'#1e3a08']]);
  ctx.fillStyle='#7a5c30';
  ctx.beginPath();ctx.moveTo(w*.44,h);ctx.lineTo(w*.48,h*.5);ctx.lineTo(w*.52,h*.5);ctx.lineTo(w*.56,h);ctx.fill();
  ctx.save();ctx.globalAlpha=.06;ctx.fillStyle='#ffc840';
  for(let i=0;i<6;i++){ctx.beginPath();ctx.moveTo(w*.5,h*.28);ctx.lineTo(w*(i*.18),h*.7);ctx.lineTo(w*(i*.18+.1),h*.7);ctx.fill();}
  ctx.restore();
  const fc=['#1a4d1a','#246624','#1a5c28'];
  for(let i=0;i<12;i++){ctx.fillStyle=fc[i%3];bigTree(ctx,w*.04+i*w*.085,h*.68,w*.022,h*.36);}
  for(let i=0;i<7;i++){ctx.fillStyle='#0f2a08';bigTree(ctx,i*w*.17-w*.05,h*.84,w*.048,h*.56);}
}

function drawOcean(ctx,w,h){
  gradRect(ctx,0,0,w,h*.48,[[0,'#030d1a'],[.6,'#0d3460'],[1,'#1a6090']]);
  stars(ctx,w,h,60,h*.4,.75);
  ctx.fillStyle='#f5e8c0';circle(ctx,w*.5,h*.1,w*.04);
  const mr=ctx.createLinearGradient(0,h*.48,0,h);
  mr.addColorStop(0,'rgba(245,232,192,.35)');mr.addColorStop(.5,'rgba(245,232,192,.15)');mr.addColorStop(1,'rgba(245,232,192,0)');
  ctx.fillStyle=mr;ctx.fillRect(w*.44,h*.48,w*.12,h*.52);
  ctx.fillStyle='rgba(100,140,180,.4)';
  [[.12,.2,.09],[.42,.12,.12],[.75,.18,.09]].forEach(([cx,cy,cr])=>{
    cloud(ctx,w*cx,h*cy,w*cr);
  });
  gradRect(ctx,0,h*.48,w,h*.52,[[0,'#1a6090'],[.4,'#0d3460'],[1,'#020a14']]);
  for(let i=0;i<7;i++){
    ctx.strokeStyle=`rgba(255,255,255,${.06+i*.04})`;ctx.lineWidth=1.5+i*.3;
    const y=h*(.5+i*.075);ctx.beginPath();ctx.moveTo(0,y);
    for(let x=0;x<=w;x+=25)ctx.quadraticCurveTo(x+12,y-(4-i*.3),x+25,y);ctx.stroke();
  }
  ctx.strokeStyle='rgba(200,220,255,.6)';ctx.lineWidth=1.5;
  [[.18,.3],[.33,.25],[.62,.32],[.8,.27]].forEach(([bx,by])=>{
    ctx.beginPath();ctx.moveTo(w*bx,h*by);ctx.quadraticCurveTo(w*(bx+.025),h*(by-.025),w*(bx+.05),h*by);ctx.stroke();
  });
}

function drawDesert(ctx,w,h){
  gradRect(ctx,0,0,w,h*.55,[[0,'#1a0a00'],[.4,'#8b3a00'],[1,'#f08020']]);
  stars(ctx,w,h,30,h*.3,.6);
  ctx.fillStyle='rgba(255,240,80,.95)';circle(ctx,w*.5,h*.52,w*.065);
  ctx.fillStyle='rgba(255,220,60,.12)';circle(ctx,w*.5,h*.52,w*.13);
  gradRect(ctx,0,h*.55,w,h*.45,[[0,'#c87430'],[.5,'#a05820'],[1,'#703010']]);
  ctx.fillStyle='#b86820';
  ctx.beginPath();ctx.moveTo(0,h*.65);ctx.quadraticCurveTo(w*.25,h*.52,w*.55,h*.65);ctx.quadraticCurveTo(w*.75,h*.74,w,h*.62);ctx.lineTo(w,h);ctx.lineTo(0,h);ctx.fill();
  ctx.fillStyle='#8a4c14';
  ctx.beginPath();ctx.moveTo(0,h*.78);ctx.quadraticCurveTo(w*.3,h*.68,w*.6,h*.78);ctx.quadraticCurveTo(w*.8,h*.85,w,h*.75);ctx.lineTo(w,h);ctx.lineTo(0,h);ctx.fill();
  ctx.fillStyle='#2d5c1c';cactus(ctx,w*.15,h*.65,w*.018,h*.18);cactus(ctx,w*.78,h*.62,w*.015,h*.15);
}

function drawSnow(ctx,w,h){
  gradRect(ctx,0,0,w,h,[[0,'#1a2a3a'],[.5,'#4a6080'],[1,'#8ab0c8']]);
  ctx.fillStyle='rgba(255,255,255,.9)';
  // Snow-capped mountains
  ctx.fillStyle='#3a5068';tri(ctx,0,h,w*.3,h*.3,w*.6,h);
  ctx.fillStyle='#2a3c50';tri(ctx,w*.3,h,w*.65,h*.2,w,h);
  ctx.fillStyle='#f0f4f8';tri(ctx,w*.3,h*.3,w*.22,h*.42,w*.38,h*.42);
  tri(ctx,w*.65,h*.2,w*.56,h*.34,w*.74,h*.34);
  gradRect(ctx,0,h*.72,w,h*.28,[[0,'#e8eef4'],[1,'#c4d4e0']]);
  // Snow texture
  ctx.strokeStyle='rgba(200,220,240,.4)';ctx.lineWidth=1;
  for(let i=0;i<6;i++){ctx.beginPath();ctx.moveTo(0,h*(.74+i*.04));ctx.lineTo(w,h*(.75+i*.04));ctx.stroke();}
  // Snowflakes
  ctx.fillStyle='rgba(255,255,255,.6)';
  for(let i=0;i<50;i++)circle(ctx,Math.random()*w,Math.random()*h*.7,.8+Math.random()*1.5);
  // Pine trees in snow
  ctx.fillStyle='#1a3020';
  for(let i=0;i<9;i++)pineTree(ctx,w*.05+i*w*.11,h*.72,w*.022,h*.18);
  // Snow on trees
  ctx.fillStyle='rgba(230,240,250,.7)';
  for(let i=0;i<9;i++){const x=w*.05+i*w*.11;ctx.beginPath();ctx.moveTo(x,h*.72-h*.18);ctx.lineTo(x-w*.015,h*.72-h*.1);ctx.lineTo(x+w*.015,h*.72-h*.1);ctx.fill();}
}

function drawAutumn(ctx,w,h){
  gradRect(ctx,0,0,w,h*.45,[[0,'#1a0a00'],[.5,'#4a2a10'],[1,'#c87030']]);
  ctx.fillStyle='rgba(255,180,60,.8)';circle(ctx,w*.7,h*.2,w*.06);
  ctx.fillStyle='rgba(255,180,60,.12)';circle(ctx,w*.7,h*.2,w*.12);
  gradRect(ctx,0,h*.7,w,h*.3,[[0,'#4a3010'],[1,'#2a1a08']]);
  // Fallen leaves on ground
  const leafCols=['#c84010','#e06020','#d09010','#a03020','#b86820'];
  for(let i=0;i<30;i++){
    ctx.fillStyle=leafCols[i%5];ctx.save();ctx.translate(Math.random()*w,h*.72+Math.random()*h*.25);
    ctx.rotate(Math.random()*Math.PI*2);ctx.beginPath();ctx.ellipse(0,0,6,4,0,0,Math.PI*2);ctx.fill();ctx.restore();
  }
  // Autumn trees
