  // Alien rock formations
  ctx.fillStyle='#2a1840';
  [[.1,h*.55,h*.15],[.3,h*.55,h*.22],[.5,h*.55,h*.18],[.65,h*.55,h*.25],[.85,h*.55,h*.12]].forEach(([rx,base,rh])=>{
    ctx.beginPath();ctx.moveTo(w*rx-w*.06,base);ctx.lineTo(w*rx,base-rh);ctx.lineTo(w*rx+w*.06,base);ctx.fill();
  });
  // Glowing flora
  ['#40ff80','#80ff40','#00ffc0','#40c0ff'].forEach((col,i)=>{
