  ctx.fillStyle='rgba(255,255,255,.5)';cloud(ctx,w*.2,h*.15,w*.05);
  gradRect(ctx,0,h*.55,w,h*.45,[[0,'#a07020'],[.5,'#806010'],[1,'#503808']]);
  // Dry grass tufts
  ctx.strokeStyle='#c09030';ctx.lineWidth=1.5;
  for(let i=0;i<40;i++){
    const gx=Math.random()*w,gy=h*(.55+Math.random()*.4);
    ctx.beginPath();ctx.moveTo(gx,gy);ctx.lineTo(gx+(-4+Math.random()*8),gy-8-Math.random()*10);ctx.stroke();
  }
  // Acacia trees
  function acacia(ax,ay){
    ctx.fillStyle='#5a3a10';ctx.fillRect(ax-5,ay-h*.2,10,h*.2);
    // Flat top canopy
    ctx.fillStyle='#2a5a10';ctx.beginPath();ctx.ellipse(ax,ay-h*.2,w*.07,h*.04,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#3a6a18';ctx.beginPath();ctx.ellipse(ax,ay-h*.22,w*.055,h*.03,0,0,Math.PI*2);ctx.fill();
  }
  acacia(w*.15,h*.7);acacia(w*.38,h*.68);acacia(w*.7,h*.72);acacia(w*.9,h*.65);
  // Giraffe silhouette
  const gx=w*.52,gy=h*.58;
  ctx.fillStyle='#c08030';
  ctx.fillRect(gx-6,gy-h*.3,12,h*.3);
  ctx.fillRect(gx-14,gy,28,h*.14);
  ctx.fillRect(gx-12,gy+h*.12,8,h*.1);ctx.fillRect(gx+4,gy+h*.12,8,h*.1);
  // Neck+head
  ctx.fillRect(gx-4,gy-h*.45,8,h*.18);
  circle(ctx,gx,gy-h*.46,10);
  // Spots
  ctx.fillStyle='#8a5018';
  [[0,-.05],[-.04,-.15],[.02,-.25],[-.02,-.02]].forEach(([dx,dy])=>circle(ctx,gx+dx*w*.1,gy+dy*h,4));
  // Birds
  ctx.strokeStyle='rgba(50,30,10,.7)';ctx.lineWidth=1.5;
  [[.3,.2],[.45,.15],[.6,.22]].forEach(([bx,by])=>{
    ctx.beginPath();ctx.moveTo(w*bx,h*by);ctx.quadraticCurveTo(w*(bx+.025),h*(by-.02),w*(bx+.05),h*by);ctx.stroke();
  });
}

function drawReef(ctx,w,h){
  gradRect(ctx,0,0,w,h,[[0,'#000a14'],[.3,'#001428'],[.6,'#002840'],[1,'#003050']]);
  // Light rays from surface
  ctx.save();ctx.globalAlpha=.06;ctx.fillStyle='#40c0ff';
  for(let i=0;i<8;i++){ctx.beginPath();ctx.moveTo(w*(i*.14),0);ctx.lineTo(w*(i*.14-.06),h);ctx.lineTo(w*(i*.14+.06),h);ctx.fill();}
  ctx.restore();
  // Seafloor
  gradRect(ctx,0,h*.78,w,h*.22,[[0,'#1a1008'],[1,'#0a0804']]);
  // Coral formations
  const coralCols=['#e04060','#ff6030','#e0a000','#a040c0','#20c080'];
  function coral(cx,cy,type,col){
    ctx.fillStyle=col;
    if(type===0){for(let i=0;i<6;i++){const a=i/6*Math.PI*2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(a)*20,cy+Math.sin(a)*20);ctx.lineTo(cx+Math.cos(a+.3)*15,cy+Math.sin(a+.3)*15);ctx.fill();}}
    else if(type===1){ctx.beginPath();ctx.moveTo(cx-10,cy);ctx.lineTo(cx,cy-30);ctx.lineTo(cx+10,cy);ctx.fill();ctx.beginPath();ctx.moveTo(cx-18,cy);ctx.lineTo(cx-8,cy-20);ctx.lineTo(cx-4,cy);ctx.fill();ctx.beginPath();ctx.moveTo(cx+4,cy);ctx.lineTo(cx+12,cy-22);ctx.lineTo(cx+20,cy);ctx.fill();}
    else{for(let r=0;r<4;r++){const y2=cy-r*8;ctx.beginPath();ctx.ellipse(cx,y2,10-r*1.5,4,0,0,Math.PI*2);ctx.fill();}}
  }
  for(let i=0;i<10;i++)coral(w*(.05+i*.1),h*(.78+Math.random()*.1),i%3,coralCols[i%5]);
  // Fish
  function fish(fx,fy,sz,col1,col2){
    ctx.fillStyle=col1;ctx.beginPath();ctx.ellipse(fx,fy,sz*2,sz*.8,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=col2;ctx.beginPath();ctx.moveTo(fx-sz*1.8,fy);ctx.lineTo(fx-sz*2.5,fy-sz);ctx.lineTo(fx-sz*2.5,fy+sz);ctx.fill();
    ctx.fillStyle=col2;ctx.strokeStyle=col2;ctx.lineWidth=1;
    for(let i=0;i<3;i++){ctx.beginPath();ctx.moveTo(fx-sz+i*sz*.6,fy-sz*.6);ctx.lineTo(fx-sz+i*sz*.6,fy+sz*.6);ctx.stroke();}
    ctx.fillStyle='rgba(0,0,0,.6)';circle(ctx,fx+sz*1.4,fy-sz*.2,sz*.25);
    ctx.fillStyle='rgba(255,255,255,.5)';circle(ctx,fx+sz*1.5,fy-sz*.25,sz*.12);
  }
  fish(w*.3,h*.3,9,'#ff6010','#ff2000');
  fish(w*.6,h*.45,7,'#0060ff','#40c0ff');
  fish(w*.15,h*.5,6,'#ffff00','#ff8000');
  fish(w*.75,h*.3,8,'#ff40a0','#ff8040');
  fish(w*.5,h*.6,5,'#40ff80','#008040');
  // Bubbles
  ctx.strokeStyle='rgba(150,220,255,.3)';ctx.lineWidth=1;
  for(let i=0;i<15;i++){const bx=Math.random()*w,by=Math.random()*h;ctx.beginPath();ctx.arc(bx,by,2+Math.random()*4,0,Math.PI*2);ctx.stroke();}
}

function drawBirds(ctx,w,h){
  gradRect(ctx,0,0,w,h*.55,[[0,'#060810'],[.3,'#0a1828'],[.6,'#1a3050'],[1,'#e06030']]);
  ctx.fillStyle='rgba(240,140,60,.9)';circle(ctx,w*.5,h*.48,w*.065);
  ctx.fillStyle='rgba(240,120,40,.18)';circle(ctx,w*.5,h*.48,w*.12);
  ctx.fillStyle='rgba(255,255,255,.7)';
  cloud(ctx,w*.12,h*.2,w*.055);cloud(ctx,w*.78,h*.15,w*.06);cloud(ctx,w*.45,h*.1,w*.04);
  gradRect(ctx,0,h*.55,w,h*.45,[[0,'#1a3010'],[1,'#0a1808']]);
  // Rolling hills
  ctx.fillStyle='#142a0a';
  ctx.beginPath();ctx.moveTo(0,h*.55);ctx.quadraticCurveTo(w*.3,h*.45,w*.6,h*.55);ctx.quadraticCurveTo(w*.8,h*.62,w,h*.55);ctx.lineTo(w,h);ctx.lineTo(0,h);ctx.fill();
  // Birds (V shapes) in flocks
  function birdFlock(cx,cy,count,spread,sz){
    for(let i=0;i<count;i++){
      const bx=cx+(-count/2+i)*spread+(Math.random()-.5)*spread*.5;
      const by=cy+(Math.random()-.5)*spread*.3+Math.abs(i-count/2)*spread*.15;
      ctx.strokeStyle='rgba(20,10,5,.8)';ctx.lineWidth=sz;
      ctx.beginPath();ctx.moveTo(bx-sz*4,by);ctx.quadraticCurveTo(bx,by-sz*2,bx+sz*4,by);ctx.stroke();
    }
  }
  birdFlock(w*.4,h*.15,8,18,1.5);
  birdFlock(w*.6,h*.25,6,14,1.3);
  birdFlock(w*.25,h*.3,5,12,1.2);
  birdFlock(w*.75,h*.2,10,20,1.6);
  birdFlock(w*.5,h*.08,4,10,1.1);
  // Trees
  ctx.fillStyle='#0a2008';
  for(let i=0;i<6;i++)bigTree(ctx,w*(.08+i*.17),h*.55,w*.025,h*.2);
}

// ── Game logic ────────────────────────────────────────────────────────
function mkCanvas(){mc=document.createElement('canvas');mc.width=CS;mc.height=CS;mx=mc.getContext('2d');SCENES[imgIdx].fn(mx,CS,CS);}
function sh(arr){for(let i=arr.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[arr[i],arr[j]]=[arr[j],arr[i]];}return arr;}

function ng(){
  clearInterval(tInt);moves=0;secs=0;going=false;sel=null;
  
  
  
  document.getElementById('wm').textContent='';
  document.getElementById('ht').textContent='Select a piece from the tray, then click a slot on the board.';
  mkCanvas();drawPrev();
  SZ=Math.floor(CS/N);
  bState=Array(N*N).fill(null);
  pieces=sh(Array.from({length:N*N},(_,i)=>i));
  renderBoard();renderTray();
}

function drawPrev(){
  const pc=document.getElementById('prev'),pctx=pc.getContext('2d');
  pctx.clearRect(0,0,110,110);
  if(showPrev){pctx.drawImage(mc,0,0,110,110);}
  else{pctx.fillStyle='#1a1a1e';pctx.fillRect(0,0,110,110);pctx.fillStyle='rgba(200,169,110,.5)';pctx.font='12px DM Mono,monospace';pctx.textAlign='center';pctx.fillText('hidden',55,60);}
}

function mkPC(pi,size){
  const c=document.createElement('canvas');c.width=size;c.height=size;
  const ctx=c.getContext('2d');
  const row=Math.floor(pi/N),col=pi%N;
  ctx.drawImage(mc,col*SZ,row*SZ,SZ,SZ,0,0,size,size);
  return c;
}

function renderBoard(){
  const bd=document.getElementById('board');
  bd.style.width=SZ*N+'px';bd.style.height=SZ*N+'px';
  bd.innerHTML='';
  for(let i=0;i<N*N;i++){
    const row=Math.floor(i/N),col=i%N;
    const slot=document.createElement('div');
    slot.className='slot'+(bState[i]!==null?' filled':'');
    slot.style.cssText=`left:${col*SZ}px;top:${row*SZ}px;width:${SZ}px;height:${SZ}px;`;
    if(bState[i]!==null){
      const c=mkPC(bState[i],SZ);
      if(bState[i]===i)c.classList.add('correct-glow');
      slot.appendChild(c);
    }
    if(bState[i]===null)slot.addEventListener('click',()=>slotClick(i));
    bd.appendChild(slot);
  }
}

function renderTray(){
  const tr=document.getElementById('tray');
  tr.innerHTML='';
  const rem=pieces.filter(p=>!bState.includes(p));
  const tsz=Math.min(70, Math.max(44, SZ));
  tr.style.width='';
  rem.forEach(pi=>{
    const wrap=document.createElement('div');
    wrap.className='piece'+(sel===pi?' sel':'');
    wrap.style.cssText=`width:${tsz}px;height:${tsz}px;`;
    wrap.appendChild(mkPC(pi,tsz));
    wrap.addEventListener('click',()=>selPiece(pi));
    tr.appendChild(wrap);
  });
  if(!rem.length)tr.innerHTML='<span style="font-size:11px;color:rgba(240,237,232,.4);padding:8px 16px;">All pieces placed!</span>';
}

function selPiece(pi){
  sel=sel===pi?null:pi;
  document.getElementById('ht').textContent=sel!==null?'Now click a board slot to place it.':'Select a piece from the tray.';
  renderTray();
}

function slotClick(idx){
  if(sel===null){document.getElementById('ht').textContent='Select a piece from the tray first!';return;}
  if(bState[idx]!==null)return;
  bState[idx]=sel;
  if(!going){going=true;tInt=setInterval(()=>{secs++;},1000);}
  moves++;
  sel=null;
  const correct=bState[idx]===idx;
  
  if(correct){
    document.getElementById('ht').textContent='Correct! Select another piece.';
    renderBoard();renderTray();checkWin();
  } else {
    renderBoard();renderTray();
    const allSlots=document.getElementById('board').querySelectorAll('.slot');
    const slot=allSlots[idx];
    if(slot){
      slot.style.background='rgba(220,60,60,.3)';
      const pc=slot.querySelector('canvas');
      if(pc){pc.style.transition='transform 0.15s ease-in';pc.style.transform='scale(1.1)';setTimeout(()=>{pc.style.transform='scale(0)';pc.style.transition='transform 0.2s ease-in';},150);}
      setTimeout(()=>{bState[idx]=null;document.getElementById('ht').textContent='Not quite — piece bounced back to tray.';renderBoard();renderTray();},400);
    }
  }
}

function checkWin(){
  if(bState.every((v,i)=>v===i)){clearInterval(tInt);const wm=Math.floor(secs/60),ws=secs%60;document.getElementById('wm').textContent='✦ Puzzle complete — '+moves+' moves in '+wm+':'+(ws<10?'0':'')+ws+' ✦';}
}

function togPrev(){showPrev=!showPrev;drawPrev();}
function setN(n){N=n;document.querySelectorAll('.diff-btn').forEach((b,i)=>b.classList.toggle('on',[3,4,5][i]===n));ng();}

// ── Build UI ─────────────────────────────────────────────────────────
const CATS=[...new Set(SCENES.map(s=>s.cat))];
const catTabsEl=document.getElementById('cat-tabs');
const imgPickerEl=document.getElementById('img-picker');

function switchCat(cat){
  curCat=cat;
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.toggle('on',b.dataset.cat===cat));
  renderImgPicker();
  // Pick first scene in category
  const first=SCENES.findIndex(s=>s.cat===cat);
  if(first>=0){imgIdx=first;ng();}
}

function renderImgPicker(){
  imgPickerEl.innerHTML='';
  SCENES.forEach((s,i)=>{
    if(s.cat!==curCat)return;
    const b=document.createElement('button');
    b.className='img-btn'+(i===imgIdx?' on':'');
    b.textContent=s.name;
    b.onclick=()=>{imgIdx=i;document.querySelectorAll('.img-btn').forEach((x,j)=>x.classList.toggle('on',j===i));ng();};
    imgPickerEl.appendChild(b);
  });
}

CATS.forEach(cat=>{
  const b=document.createElement('button');
  b.className='cat-btn'+(cat===curCat?' on':'');
  b.dataset.cat=cat;b.textContent=cat;
  b.onclick=()=>switchCat(cat);
  catTabsEl.appendChild(b);
});

renderImgPicker();
ng();

// ── Audio Engine (Web Audio API) ────────────────────────────────────
let audioCtx = null, musicGain = null, sfxGain = null;
let musicPlaying = false, musicOscillators = [], musicInterval = null;

function getAudioCtx(){
  if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if(audioCtx.state === 'suspended') audioCtx.resume();
  if(!musicGain){ musicGain = audioCtx.createGain(); musicGain.gain.value = 0.18; musicGain.connect(audioCtx.destination); }
  if(!sfxGain){ sfxGain = audioCtx.createGain(); sfxGain.gain.value = 0.35; sfxGain.connect(audioCtx.destination); }
  return audioCtx;
}

function playTone(freq, type, duration, gainVal, startTime, destination){
  const ctx = getAudioCtx();
  const osc = ctx.createOscillator();
  const g = ctx.createGain();
  osc.type = type || 'sine';
  osc.frequency.setValueAtTime(freq, startTime || ctx.currentTime);
  g.gain.setValueAtTime(gainVal || 0.2, startTime || ctx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001, (startTime || ctx.currentTime) + duration);
  osc.connect(g);
  g.connect(destination || sfxGain);
  osc.start(startTime || ctx.currentTime);
  osc.stop((startTime || ctx.currentTime) + duration + 0.05);
}

// Sound effects
function sfxSelect(){ playTone(520, 'sine', 0.12, 0.5); }
function sfxDeselect(){ playTone(380, 'sine', 0.1, 0.3); }
function sfxCorrect(){
  const ctx = getAudioCtx(); const now = ctx.currentTime;
  playTone(523, 'sine', 0.12, 0.5, now);
  playTone(659, 'sine', 0.12, 0.5, now + 0.1);
  playTone(784, 'sine', 0.2, 0.5, now + 0.2);
}
function sfxWrong(){
  const ctx = getAudioCtx(); const now = ctx.currentTime;
  playTone(220, 'sawtooth', 0.08, 0.4, now);
  playTone(180, 'sawtooth', 0.1, 0.4, now + 0.08);
}
function sfxWin(){
  const ctx = getAudioCtx(); const now = ctx.currentTime;
  const melody = [523,659,784,1047,784,1047,1175,1319];
  melody.forEach((f,i) => playTone(f, 'sine', 0.25, 0.5, now + i*0.12));
}
function sfxNav(){ playTone(440, 'triangle', 0.06, 0.25); }

// Background music - gentle ambient arpeggio
const MUSIC_NOTES = [261,329,392,523,392,329,261,220,262,330,392,494,392,330];
let musicNoteIdx = 0;
function startMusic(){
  if(musicPlaying) return;
  musicPlaying = true;
  getAudioCtx();
  musicInterval = setInterval(()=>{
    if(!musicPlaying) return;
    const note = MUSIC_NOTES[musicNoteIdx % MUSIC_NOTES.length];
    musicNoteIdx++;
    playTone(note, 'triangle', 0.45, 0.6, null, musicGain);
    // Occasional harmony
    if(musicNoteIdx % 4 === 0) playTone(note * 1.5, 'sine', 0.4, 0.3, null, musicGain);
  }, 480);
  document.getElementById('music-btn').textContent = '🔇';
}
function stopMusic(){
  musicPlaying = false;
  if(musicInterval){ clearInterval(musicInterval); musicInterval = null; }
  document.getElementById('music-btn').textContent = '🎵';
}
function toggleMusic(){
  getAudioCtx();
  musicPlaying ? stopMusic() : startMusic();
}

// Patch game functions to emit sounds
const _origSelPiece = selPiece;
selPiece = function(pi){
  if(sel === pi){ sfxDeselect(); } else { sfxSelect(); }
  _origSelPiece(pi);
};

const _origSlotClick = slotClick;
slotClick = function(idx){
  // We detect correct/wrong after the fact by watching bState
  const prevSel = sel;
  _origSlotClick(idx);
  // slotClick sets sel=null after placement; check if a piece was placed
  if(prevSel !== null && prevSel !== undefined){
    if(bState[idx] === idx){ sfxCorrect(); }
    else {
      // piece was placed wrong (will bounce back)
      sfxWrong();
    }
  }
};

const _origCheckWin = checkWin;
checkWin = function(){
  const wasDone = bState.every((v,i)=>v===i);
  _origCheckWin();
  if(wasDone) setTimeout(sfxWin, 50);
};

// ── Touch Controls ───────────────────────────────────────────────────
let isTouchDevice = false;
let trayFocusIdx = 0; // index into remaining pieces in tray

function detectTouch(){
  isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
  const tc = document.getElementById('touch-controls');
  const kbHint = document.getElementById('kb-hint');
  if(isTouchDevice){ tc.classList.add('visible'); }
  else { kbHint.style.display = 'block'; }
}

function getTrayPieces(){
  return pieces.filter(p => !bState.includes(p));
}

function trayNavLeft(){
  sfxNav();
  const rem = getTrayPieces();
  if(!rem.length) return;
  trayFocusIdx = (trayFocusIdx - 1 + rem.length) % rem.length;
  highlightTrayFocus();
}
function trayNavRight(){
  sfxNav();
  const rem = getTrayPieces();
  if(!rem.length) return;
  trayFocusIdx = (trayFocusIdx + 1) % rem.length;
  highlightTrayFocus();
}
function highlightTrayFocus(){
  const rem = getTrayPieces();
  if(!rem.length) return;
  trayFocusIdx = Math.min(trayFocusIdx, rem.length - 1);
  const pieces_el = document.getElementById('tray').querySelectorAll('.piece');
  pieces_el.forEach((el, i) => {
    el.style.outline = i === trayFocusIdx ? '2px solid var(--accent2)' : '';
  });
  // Scroll focused piece into view
  if(pieces_el[trayFocusIdx]) pieces_el[trayFocusIdx].scrollIntoView({behavior:'smooth',inline:'center',block:'nearest'});
}

function touchSelectOrPlace(){
  sfxSelect();
  const rem = getTrayPieces();
  if(!rem.length) return;
  trayFocusIdx = Math.min(trayFocusIdx, rem.length - 1);
  if(sel === null){
    // Select highlighted tray piece
    selPiece(rem[trayFocusIdx]);
  } else {
    // Find first empty slot and place
    const emptySlot = bState.findIndex(v => v === null);
    if(emptySlot >= 0) slotClick(emptySlot);
  }
}

// Wire touch buttons
document.addEventListener('DOMContentLoaded', ()=>{
  detectTouch();
  document.getElementById('tc-left').addEventListener('click', trayNavLeft);
  document.getElementById('tc-right').addEventListener('click', trayNavRight);
  document.getElementById('tc-select').addEventListener('click', touchSelectOrPlace);
  document.getElementById('tc-new').addEventListener('click', ()=>{ sfxDeselect(); ng(); });
  document.getElementById('tc-prev').addEventListener('click', ()=>{ togPrev(); sfxNav(); });
  document.getElementById('tc-music').addEventListener('click', toggleMusic);
});

// ── Keyboard Controls ────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  // Don't fire on input elements
  if(e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
  switch(e.key){
    case 'ArrowLeft':  e.preventDefault(); trayNavLeft(); break;
    case 'ArrowRight': e.preventDefault(); trayNavRight(); break;
    case 'Enter':
    case ' ':          e.preventDefault(); touchSelectOrPlace(); break;
    case 'n': case 'N': ng(); sfxDeselect(); break;
    case 'p': case 'P': togPrev(); sfxNav(); break;
    case 'm': case 'M': toggleMusic(); break;
  }
});

// Also re-highlight focus after renderTray
const _origRenderTray = renderTray;
renderTray = function(){
  _origRenderTray();
  const rem = getTrayPieces();
  if(rem.length){ trayFocusIdx = Math.min(trayFocusIdx, rem.length-1); if(!isTouchDevice) highlightTrayFocus(); }
};

detectTouch();

</script>
