function drawKoi(ctx,w,h){
  gradRect(ctx,0,0,w,h,[[0,'#0a2a1a'],[.4,'#0a3a28'],[1,'#062018']]);
  // Lily pads
  const pads=[[.2,.3,w*.07],[.7,.6,w*.08],[.45,.8,w*.06],[.85,.25,w*.055],[.1,.7,w*.05]];
  pads.forEach(([px,py,pr])=>{
    ctx.fillStyle='#1a5a18';ctx.beginPath();ctx.arc(w*px,h*py,pr,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='#0a3a10';ctx.beginPath();ctx.moveTo(w*px,h*py);ctx.lineTo(w*px+pr*.8,h*py-pr*.3);ctx.lineTo(w*px,h*py);ctx.stroke();
    // Flower
    ctx.fillStyle='rgba(255,180,180,.8)';circle(ctx,w*px,h*py,pr*.25);
    ctx.fillStyle='rgba(255,220,80,.9)';circle(ctx,w*px,h*py,pr*.1);
  });
  // Water ripples
  ctx.strokeStyle='rgba(255,255,255,.06)';ctx.lineWidth=1;
  [[.4,.4],[.6,.7],[.25,.6]].forEach(([rx,ry])=>{
    for(let r=1;r<5;r++){ctx.beginPath();ctx.ellipse(w*rx,h*ry,r*8,r*5,0,0,Math.PI*2);ctx.stroke();}
  });
  // Koi fish
  function koi(fx,fy,angle,col1,col2,sz){
    ctx.save();ctx.translate(fx,fy);ctx.rotate(angle);
    ctx.fillStyle=col1;ctx.beginPath();ctx.ellipse(0,0,sz*2,sz*.8,0,0,Math.PI*2);ctx.fill();
    ctx.fillStyle=col2;
    ctx.beginPath();ctx.ellipse(sz*.4,0,sz*.8,sz*.5,0,0,Math.PI*2);ctx.fill();
    circle(ctx,-sz*.6,sz*.3,sz*.2);circle(ctx,-sz*.6,-sz*.3,sz*.2);
    ctx.fillStyle='rgba(0,0,0,.5)';circle(ctx,sz*1.5,-sz*.3,sz*.15);
    ctx.restore();
  }
  koi(w*.35,h*.35,.3,'#e06020','#fff0d0',14);
  koi(w*.6,h*.55,-.8,'#f0f0f0','#e04040',16);
  koi(w*.2,h*.65,1.2,'#e08010','#ffffff',12);
  koi(w*.75,h*.35,-1.4,'#c02010','#e09020',13);
  koi(w*.5,h*.2,.6,'#f0f0f0','#f08040',11);
}

function drawArctic(ctx,w,h){
  gradRect(ctx,0,0,w,h*.5,[[0,'#0a1428'],[.5,'#1a3050'],[1,'#3a6080']]);
  stars(ctx,w,h,50,h*.4,.7);
  // Aurora
  const aurG=ctx.createLinearGradient(0,h*.05,0,h*.45);
  aurG.addColorStop(0,'rgba(0,255,120,0)');aurG.addColorStop(.3,'rgba(0,255,120,.1)');aurG.addColorStop(.7,'rgba(0,200,255,.08)');aurG.addColorStop(1,'rgba(0,255,120,0)');
  ctx.fillStyle=aurG;ctx.fillRect(0,0,w,h*.45);
  gradRect(ctx,0,h*.5,w,h*.5,[[0,'#d0e8f8'],[.5,'#b0d0e8'],[1,'#8ab0c8']]);
  // Ice chunks
  ctx.fillStyle='#c0d8ec';
  [[.05,.55,.15,.08],[.25,.58,.2,.06],[.5,.56,.18,.07],[.72,.57,.16,.06],[.88,.55,.12,.07]].forEach(([ix,iy,iw,ih])=>{
    ctx.beginPath();ctx.moveTo(w*ix,h*iy);ctx.lineTo(w*(ix+iw*.3),h*(iy-ih));ctx.lineTo(w*(ix+iw*.7),h*(iy-ih*.5));ctx.lineTo(w*(ix+iw),h*iy);ctx.fill();
  });
  // Arctic fox
  const fx=w*.45,fy=h*.68;
  ctx.fillStyle='#f0f0f0';
  ctx.beginPath();ctx.ellipse(fx,fy,w*.06,h*.04,0,0,Math.PI*2);ctx.fill();
  circle(ctx,fx+w*.055,fy-h*.01,w*.025);
  ctx.fillStyle='#e8e8e8';
  ctx.beginPath();ctx.ellipse(fx-w*.03,fy+h*.03,w*.015,h*.025,.3,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(fx+w*.03,fy+h*.03,w*.015,h*.025,-.3,0,Math.PI*2);ctx.fill();
  // Ears
  ctx.fillStyle='#f0f0f0';
  tri(ctx,fx+w*.04,fy-h*.03,fx+w*.055,fy-h*.055,fx+w*.07,fy-h*.03);
  tri(ctx,fx+w*.06,fy-h*.025,fx+w*.075,fy-h*.05,fx+w*.085,fy-h*.025);
  ctx.fillStyle='#2a2020';circle(ctx,fx+w*.065,fy-h*.012,2);
  ctx.fillStyle='#e08080';circle(ctx,fx+w*.072,fy-h*.008,1.5);
  // Fluffy tail
  ctx.fillStyle='#f0f0f0';ctx.beginPath();ctx.ellipse(fx-w*.08,fy,w*.04,h*.025,.4,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#fff';ctx.beginPath();ctx.ellipse(fx-w*.09,fy,w*.025,h*.015,.4,0,Math.PI*2);ctx.fill();
  // Snow falling
  ctx.fillStyle='rgba(255,255,255,.6)';
  for(let i=0;i<30;i++)circle(ctx,Math.random()*w,Math.random()*h*.5,1+Math.random());
}

function drawJungle(ctx,w,h){
  gradRect(ctx,0,0,w,h*.3,[[0,'#0a1a08'],[1,'#1a3a10']]);
  gradRect(ctx,0,h*.7,w,h*.3,[[0,'#0a1a08'],[1,'#050e04']]);
  // Dense jungle background
  ctx.fillStyle='#0d2a0a';ctx.fillRect(0,0,w,h);
  // Shafts of light
  ctx.save();ctx.globalAlpha=.07;ctx.fillStyle='#80ff40';
  for(let i=0;i<5;i++){ctx.beginPath();ctx.moveTo(w*(.1+i*.2),0);ctx.lineTo(w*(.07+i*.2),h);ctx.lineTo(w*(.13+i*.2),h);ctx.fill();}
  ctx.restore();
  // Vines
  ctx.strokeStyle='#1a4a10';ctx.lineWidth=3;
  for(let i=0;i<6;i++){
    ctx.beginPath();ctx.moveTo(w*(i*.18),0);
    for(let y=0;y<h;y+=30)ctx.lineTo(w*(i*.18+Math.sin(y*.05+i)*.04),y);ctx.stroke();
  }
  // Large leaves
  const leafCols=['#1a5a10','#205a15','#1a6a0a','#2a5a18'];
  for(let i=0;i<20;i++){
    ctx.fillStyle=leafCols[i%4];ctx.save();
    ctx.translate(Math.random()*w,Math.random()*h);ctx.rotate(Math.random()*Math.PI*2);
    ctx.beginPath();ctx.ellipse(0,0,20+Math.random()*25,8+Math.random()*12,0,0,Math.PI*2);ctx.fill();ctx.restore();
  }
  // Bright flowers
  const flCols=['#ff4060','#ff8020','#fff040','#ff20a0'];
  for(let i=0;i<12;i++){
    const fx=Math.random()*w,fy=Math.random()*h;
    ctx.fillStyle=flCols[i%4];circle(ctx,fx,fy,5+Math.random()*6);
    ctx.fillStyle='#fff040';circle(ctx,fx,fy,2);
  }
  // Butterfly
  const bx=w*.55,by=h*.35;
  ctx.fillStyle='rgba(255,100,200,.8)';
  ctx.beginPath();ctx.ellipse(bx-10,by-5,12,8,-.4,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(bx+10,by-5,12,8,.4,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,200,50,.7)';
  ctx.beginPath();ctx.ellipse(bx-8,by+4,8,5,-.6,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(bx+8,by+4,8,5,.6,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#1a0a00';ctx.fillRect(bx-1,by-12,2,16);
}

function drawSavanna(ctx,w,h){
  gradRect(ctx,0,0,w,h*.55,[[0,'#0a0500'],[.3,'#3a1a00'],[.6,'#c06010'],[1,'#e09030']]);
