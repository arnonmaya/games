    [w*.4,h*.4,w*.5,'rgba(120,40,180,.25)'],
    [w*.6,h*.3,w*.4,'rgba(40,80,200,.2)'],
    [w*.25,h*.6,w*.4,'rgba(180,60,100,.2)'],
    [w*.7,h*.65,w*.3,'rgba(40,160,120,.15)'],
