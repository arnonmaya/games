  });
  // Alien river
  const alr=ctx.createLinearGradient(0,h*.7,w,h*.8);
  alr.addColorStop(0,'#0040a0');alr.addColorStop(.5,'#0080ff');alr.addColorStop(1,'#0040a0');
  ctx.fillStyle=alr;
  ctx.beginPath();ctx.moveTo(0,h*.72);ctx.quadraticCurveTo(w*.5,h*.68,w,h*.74);ctx.lineTo(w,h*.78);ctx.quadraticCurveTo(w*.5,h*.74,0,h*.76);ctx.fill();
}

function drawSolar(ctx,w,h){
  ctx.fillStyle='#000008';ctx.fillRect(0,0,w,h);
  stars(ctx,w,h,120,h,.7);
  // Sun
  const sunG=ctx.createRadialGradient(w*.5,h*.5,0,w*.5,h*.5,w*.07);
  sunG.addColorStop(0,'#ffffd0');sunG.addColorStop(.3,'#ffd040');sunG.addColorStop(.6,'#ff8010');sunG.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=sunG;ctx.fillRect(w*.4,h*.4,w*.2,h*.2);
  ctx.fillStyle='#fff8a0';circle(ctx,w*.5,h*.5,w*.04);
  // Orbits
  ctx.strokeStyle='rgba(255,255,255,.06)';ctx.lineWidth=1;
  [.1,.17,.24,.32,.42,.53,.63,.73].forEach(r=>{ctx.beginPath();ctx.ellipse(w*.5,h*.5,w*r,h*r*.7,.1,0,Math.PI*2);ctx.stroke();});
  // Planets
  const planets=[
    {r:.1,a:.8,sz:3,col:'#a08060'},
    {r:.17,a:2.1,sz:5,col:'#d0a060'},
    {r:.24,a:1.2,sz:5.5,col:'#4060d0'},
    {r:.32,a:3.5,sz:4,col:'#c04020'},
    {r:.42,a:.5,sz:12,col:'#c09060'},
    {r:.53,a:2.8,sz:10,col:'#d0b880'},
    {r:.63,a:1.8,sz:7,col:'#80c0d0'},
    {r:.73,a:4,sz:7,col:'#8090d0'},
  ];
  planets.forEach(({r,a,sz,col})=>{
