function drawAurora(ctx,w,h){
  ctx.fillStyle='#020810';ctx.fillRect(0,0,w,h);
  stars(ctx,w,h,80,h*.4,.85);
  // Aurora curtains
  const aurCols=[
    ['rgba(0,255,120,.12)','rgba(0,255,120,0)'],
    ['rgba(0,180,255,.1)','rgba(0,180,255,0)'],
    ['rgba(120,0,255,.08)','rgba(120,0,255,0)'],
    ['rgba(0,255,180,.1)','rgba(0,255,180,0)'],
    ['rgba(80,255,100,.12)','rgba(80,255,100,0)'],
  ];
  aurCols.forEach(([c1,c2],i)=>{
    const x=w*(i*.2+.05);
    const ag=ctx.createLinearGradient(x,h*.1,x,h*.65);
    ag.addColorStop(0,c2);ag.addColorStop(.3,c1);ag.addColorStop(.7,c1);ag.addColorStop(1,c2);
    ctx.fillStyle=ag;
    // Wavy curtain
    ctx.beginPath();
    const wx=x+w*.08;
    ctx.moveTo(x,h*.1);
    for(let y=h*.1;y<h*.65;y+=5){
      const wave=Math.sin(y*.02+i)*w*.025;
      ctx.lineTo(x+wave,y);
    }
    for(let y=h*.65;y>h*.1;y-=5){
      const wave=Math.sin(y*.02+i)*w*.025;
      ctx.lineTo(wx+wave,y);
    }
    ctx.closePath();ctx.fill();
  });
  // Snowy ground
  gradRect(ctx,0,h*.72,w,h*.28,[[0,'#e8f0f8'],[1,'#b0c8d8']]);
  // Snow bumps
  ctx.fillStyle='#d0e0f0';
  [.1,.25,.4,.55,.7,.82,.93].forEach(bx=>{ctx.beginPath();ctx.ellipse(w*bx,h*.72,w*.08,h*.04,0,0,Math.PI*2);ctx.fill();});
  // Reflection
  ctx.save();ctx.globalAlpha=.15;
  aurCols.forEach(([c1],i)=>{
    ctx.fillStyle=c1;ctx.fillRect(w*(i*.2+.05),h*.72,w*.1,h*.28);
  });
  ctx.restore();
}

function drawAlien(ctx,w,h){
