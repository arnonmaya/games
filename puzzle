function drawStars(ctx,w,h){
  ctx.fillStyle='#000005';ctx.fillRect(0,0,w,h);
  // Many stars
  for(let i=0;i<200;i++){
    const sz=Math.random();
    ctx.fillStyle=`rgba(255,255,255,${.4+sz*.6})`;
    circle(ctx,Math.random()*w,Math.random()*h,sz*1.5);
  }
  // Milky way band
  const mw=ctx.createLinearGradient(0,h*.2,w,h*.8);
  mw.addColorStop(0,'rgba(0,0,0,0)');mw.addColorStop(.3,'rgba(180,160,220,.06)');mw.addColorStop(.5,'rgba(180,160,220,.1)');mw.addColorStop(.7,'rgba(180,160,220,.06)');mw.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=mw;ctx.fillRect(0,0,w,h);
  // Colored stars
  const cols=['#ffd0d0','#d0d0ff','#d0ffd0','#ffffd0'];
  for(let i=0;i<20;i++){ctx.fillStyle=cols[i%4];circle(ctx,Math.random()*w,Math.random()*h,1+Math.random());}
  // Shooting star
  ctx.strokeStyle='rgba(255,255,255,.7)';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(w*.6,h*.1);ctx.lineTo(w*.8,h*.25);ctx.stroke();
  ctx.strokeStyle='rgba(255,255,255,.2)';ctx.lineWidth=4;
  ctx.beginPath();ctx.moveTo(w*.6,h*.1);ctx.lineTo(w*.8,h*.25);ctx.stroke();
  // Large bright stars (cross shape)
  [[.15,.4],[.72,.2],[.5,.7],[.9,.6]].forEach(([sx,sy])=>{
    ctx.strokeStyle='rgba(255,255,200,.6)';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(w*sx-10,h*sy);ctx.lineTo(w*sx+10,h*sy);ctx.stroke();
    ctx.beginPath();ctx.moveTo(w*sx,h*sy-10);ctx.lineTo(w*sx,h*sy+10);ctx.stroke();
    ctx.fillStyle='rgba(255,255,200,.9)';circle(ctx,w*sx,h*sy,2);
  });
}

function drawNebula(ctx,w,h){
